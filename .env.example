# ─── Scheduler ─── #

# server
SCHEDULER_HOST=0.0.0.0
SCHEDULER_PORT=8080
APP_VERSION=1.0.0
DEBUG=false

# db credentials
SCHEDULER_DB_USER=user_scheduler
SCHEDULER_DB_PASSWORD=password_scheduler
SCHEDULER_DB_NAME=scheduler_db
SCHEDULER_DB_URL=postgresql://user_scheduler:password_scheduler@scheduler-db:5432/scheduler_db

# points to the executor service — matches the container name in docker-compose
EXECUTOR_BASE_URL=http://executor:8090

# cors — "*" is fine for local dev, lock it down in prod
CORS_ALLOW_ORIGINS=*

# db pool
DB_POOL_MIN_SIZE=2
DB_POOL_MAX_SIZE=10

# retry backoff — doubles each attempt: 60s, 120s, 240s…
RETRY_BASE_DELAY_SECONDS=60

# polling for async (202) webhooks
POLL_INTERVAL_SECONDS=5
POLL_MAX_ATTEMPTS=60

# webhook http client
WEBHOOK_TIMEOUT_SECONDS=30

# apscheduler — how late a job can still fire
MISFIRE_GRACE_TIME_SECONDS=300


# ─── Executor ─── #

# server
EXECUTOR_HOST=0.0.0.0
EXECUTOR_PORT=8090
DEBUG=false

# db credentials
EXECUTOR_DB_USER=user_executor
EXECUTOR_DB_PASSWORD=password_executor
EXECUTOR_DB_NAME=executor_db
EXECUTOR_DB_URL=postgresql://user_executor:password_executor@executor-db:5433/executor_db

# cors
CORS_ALLOW_ORIGINS=*

# db pool
DB_POOL_MIN_SIZE=2
DB_POOL_MAX_SIZE=10

# max time to wait for a task to finish before giving up
EXECUTION_TIMEOUT_SECONDS=300

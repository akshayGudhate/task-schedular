# ─── App ─── #
APP_VERSION=1.0.0


# ─── Scheduler ─── #
#  host and port
SCHEDULER_HOST=0.0.0.0
SCHEDULER_PORT=8080

# db credentials
SCHEDULER_DB_USER=user_scheduler
SCHEDULER_DB_PASSWORD=password_scheduler
SCHEDULER_DB_NAME=scheduler_db
SCHEDULER_DB_URL=postgresql+asyncpg://user:password@scheduler-db:5432/scheduler_db


# ─── Executor ─── #
#  host and port
EXECUTOR_HOST=0.0.0.0
EXECUTOR_PORT=8090

# executor db credentials
EXECUTOR_DB_USER=user_executor
EXECUTOR_DB_PASSWORD=password_executor
EXECUTOR_DB_NAME=executor_db
EXECUTOR_DB_URL=postgresql+asyncpg://user:password@executor-db:5432/executor_db
		{
			"name": "Scheduler — Tasks",
			"item": [
				{
					"name": "Create Task — Sync (Welcome Email)",
					"event": [
						{
							"listen": "prerequest",
							"script": {
								"exec": [
									"// set execution_time to 2 minutes from now",
									"const t = new Date(Date.now() + 2 * 60 * 1000);",
									"pm.variables.set('execution_time', t.toISOString());"
								],
								"type": "text/javascript"
							}
						},
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 201) {",
									"    const body = pm.response.json();",
									"    pm.collectionVariables.set('task_id', body.id);",
									"    pm.test('status is CREATED', () => pm.expect(body.status).to.equal('CREATED'));",
									"    pm.test('id saved to task_id', () => pm.expect(body.id).to.be.a('string'));",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{"key": "Content-Type", "value": "application/json"}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"name\": \"Send Welcome Email\",\n  \"execution_time\": \"{{execution_time}}\",\n  \"webhook_url\": \"http://executor:8090/send-welcome\",\n  \"payload\": {\n    \"email\": \"newuser@example.com\",\n    \"template\": \"welcome\"\n  },\n  \"recurrence\": \"NONE\",\n  \"max_retries\": 3\n}",
							"options": {"raw": {"language": "json"}}
						},
						"url": {
							"raw": "{{SCHEDULER_URL}}/tasks",
							"host": ["{{SCHEDULER_URL}}"],
							"path": ["tasks"]
						},
						"description": "Creates a one-shot task. At `execution_time` the scheduler POSTs to `/send-welcome` (sync — returns 200 immediately). The pre-request script sets `execution_time` to now + 2 min. The test script captures the returned `id` into `task_id`.\n\n**Task lifecycle:** `CREATED → PENDING → RUNNING → SUCCESS`"
					},
					"response": []
				},
				{
					"name": "Create Task — Async (Notify Admin)",
					"event": [
						{
							"listen": "prerequest",
							"script": {
								"exec": [
									"const t = new Date(Date.now() + 2 * 60 * 1000);",
									"pm.variables.set('execution_time', t.toISOString());"

		{
			"name": "Executor — Execution Status",
			"item": [
				{
					"name": "Poll Execution Status",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('status 200', () => pm.response.to.have.status(200));",
									"const body = pm.response.json();",
									"pm.test('status field present', () => {",
									"    pm.expect(['RECEIVED','PROCESSING','COMPLETED','FAILED']).to.include(body.status);",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{EXECUTOR_URL}}/status/{{execution_id}}",
							"host": ["{{EXECUTOR_URL}}"],
							"path": ["status", "{{execution_id}}"]
						},
						"description": "Poll the execution status of an async webhook call.\n\nUses `execution_id` captured from a previous `POST /notify-admin` or `POST /daily-report` response.\n\n**Status values:**\n| Status | Meaning |\n|---|---|\n| `RECEIVED` | Record created, background task not yet started |\n| `PROCESSING` | Background task is actively running |\n| `COMPLETED` | Finished successfully — `result` field is populated |\n| `FAILED` | Errored or timed out — `error_message` field is populated |\n\nStop polling when `COMPLETED` or `FAILED` is returned."
					},
					"response": []
				}
			]
		}
